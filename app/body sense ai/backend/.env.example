# BodySense AI — Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Stripe ────────────────────────────────────────────────────────────────
# TEST keys (sandbox):
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# LIVE keys (production — switch before App Store submission):
# STRIPE_SECRET_KEY=YOUR_LIVE_STRIPE_KEY_HERE

# Webhook secret (get from Stripe Dashboard → Webhooks):
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Firebase (optional — backend works without it in Stripe-only mode) ────
# Get from Firebase Console → Project Settings → Service Accounts
FIREBASE_PROJECT_ID=bodysenseai
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ── Anthropic AI ──────────────────────────────────────────────────────────
# Powers the AI health agents (Health Coach, Nutritionist, etc.)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Notes ─────────────────────────────────────────────────────────────────
# Stripe Price IDs to add to StripeManager.swift:
#   Pro plan  (£3.99/mo): price_XXXXXXXXXXXXXXXXXXXX  ← create in Stripe Dashboard
#   Premium   (£8.99/mo): price_XXXXXXXXXXXXXXXXXXXX  ← create in Stripe Dashboard
#
# Firebase Setup:
#   1. Go to https://console.firebase.google.com
#   2. Create project "bodysenseai"
#   3. Enable Firestore Database (production mode)
#   4. Project Settings → Service Accounts → Generate new private key
#   5. Save as firebase-service-account.json in backend/ folder
#   6. Set GOOGLE_APPLICATION_CREDENTIALS in .env
